{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":assignee(komailo)",
    ":reviewer(komailo)"
  ],
  "labels": ["dependencies", "renovate"],
  "nix": {
    "enabled": true
  },
  "postUpdateOptions": ["gomodTidy"],
  "packageRules": [
    {
      "groupName": "No-op updates",
      "matchUpdateTypes": ["digest", "pin", "pinDigest"],
      "automerge": true,
      "autoApprove": true,
      "addLabels": ["no-op"]
    },
    {
      "groupName": "Patch update",
      "matchUpdateTypes": ["patch"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true,
      "autoApprove": true,
      "bumpVersion": "patch",
      "addLabels": ["patch"]
    },
    {
      "groupName": "Minor updates",
      "matchUpdateTypes": ["minor"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true,
      "autoApprove": true,
      "bumpVersion": "minor",
      "addLabels": ["minor"]
    },
    {
      "groupName": "Major updates",
      "matchUpdateTypes": ["major"],
      "matchCurrentVersion": "!/^0/",
      "automerge": false,
      "bumpVersion": "major",
      "addLabels": ["major"]
    }
  ]
}
